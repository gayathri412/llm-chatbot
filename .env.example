GROQ_API_KEY=
GEMINI_API_KEY=

# Auth: Firebase Authentication email/password.
AUTH_PROVIDER=firebase
FIREBASE_WEB_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=

# Cache: local Redis or Google Cloud Memorystore Redis endpoint.
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
CACHE_NAMESPACE=snti-ai
REDIS_URL=
# Or configure Memorystore/Redis by host:
REDIS_HOST=
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SSL=false

# Telemetry: Cloud Logging and optional BigQuery inserts.
TELEMETRY_ENABLED=true
GCP_PROJECT_ID=
GCP_LOCATION=US
CLOUD_LOGGING_ENABLED=true
BIGQUERY_TELEMETRY_ENABLED=false
BIGQUERY_TELEMETRY_DATASET=analytics
BIGQUERY_TELEMETRY_TABLE=chat_telemetry
LOG_LEVEL=INFO

# Data layer: raw JSON -> staging GCS -> BigQuery curated context table.
GCS_STAGING_BUCKET=
BIGQUERY_RAW_DATASET=raw
BIGQUERY_CONTEXT_DATASET=analytics
BIGQUERY_CONTEXT_TABLE=chat_context_docs
BIGQUERY_EMBEDDINGS_TABLE=chat_context_embeddings
RAG_USE_BIGQUERY=false

# Secrets: read API keys from Secret Manager when enabled.
SECRET_MANAGER_ENABLED=false
GROQ_API_KEY_SECRET=groq-api-key
GEMINI_API_KEY_SECRET=gemini-api-key

# Security / audit
PII_REDACTION_ENABLED=true
AUDIT_PROMPT_PREVIEW_ENABLED=false
