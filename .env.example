GROQ_API_KEY=
GEMINI_API_KEY=

# LLM provider decision:
# Production: Vertex AI Gemini. Fallbacks: Gemini API key, then Llama via Groq.
# OpenAI and Azure OpenAI are not selected for this implementation path.
LLM_PROVIDER=vertex_gemini
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_MODEL=gemini-2.5-flash
GROQ_LLAMA_MODEL=llama-3.1-8b-instant

# Auth: Firebase Authentication email/password.
# Use AUTH_PROVIDER=firebase or AUTH_PROVIDER=oidc.
AUTH_PROVIDER=firebase
FIREBASE_WEB_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=

# Upload storage backend. Use firebase or appwrite.
APP_STORAGE_BACKEND=firebase

# Appwrite Storage. Create the bucket in Appwrite Console first.
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_STORAGE_BUCKET_ID=
# Optional comma-separated permissions, for example: read("any")
APPWRITE_FILE_PERMISSIONS=

# Enterprise SSO via OpenID Connect. Works with Azure AD or Okta.
OIDC_PROVIDER_NAME=
OIDC_DISCOVERY_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_SCOPES=openid profile email
OIDC_ALLOWED_DOMAINS=
OIDC_ALLOWED_EMAILS=

# Cache: local Redis or Google Cloud Memorystore Redis endpoint.
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
CACHE_NAMESPACE=snti-ai
TOP_QUERY_TRACKING_ENABLED=true
REDIS_URL=
# Or configure Memorystore/Redis by host:
REDIS_HOST=
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SSL=false

# Telemetry: Cloud Logging and optional BigQuery inserts.
TELEMETRY_ENABLED=true
GCP_PROJECT_ID=
GCP_LOCATION=US
CLOUD_LOGGING_ENABLED=true
BIGQUERY_TELEMETRY_ENABLED=false
BIGQUERY_TELEMETRY_DATASET=analytics
BIGQUERY_TELEMETRY_TABLE=chat_telemetry
TELEMETRY_BATCH_ENABLED=true
TELEMETRY_BATCH_SIZE=10
TELEMETRY_FLUSH_INTERVAL_SECONDS=30
LOG_LEVEL=INFO

# Data layer: raw JSON -> staging GCS -> BigQuery curated context table.
GCS_STAGING_BUCKET=
BIGQUERY_RAW_DATASET=raw
BIGQUERY_CONTEXT_DATASET=analytics
BIGQUERY_CONTEXT_TABLE=chat_context_docs
BIGQUERY_EMBEDDINGS_TABLE=chat_context_embeddings
RAG_USE_BIGQUERY=false
RAG_USE_EMBEDDINGS=false
RAG_EMBEDDING_MODEL=gemini-embedding-001
RAG_VECTOR_INDEX_PATH=.rag_index/context_vectors.json

# Data access: map enterprise identity claims to RAG/BigQuery source names.
# Rule format: selector:specific-value=source1,source2; selector:* supports all sources with *
# Selectors: role, group, email, domain, user_id
DATA_ACCESS_CONTROL_ENABLED=true
DATA_ACCESS_RULES=role:admin=*;domain:yourcompany.com=docs.json,sample.json
# Optional fallback for users who authenticate but match no rule. Leave empty to deny when rules exist.
DATA_ACCESS_DEFAULT_SOURCES=

# Token and model optimization
MAX_INPUT_TOKENS=6000
MAX_CONTEXT_TOKENS=2500
MAX_OUTPUT_TOKENS=800
MODEL_AUTO_ROUTING_ENABLED=true
CHEAP_MODEL_CHOICE=Llama
PREMIUM_MODEL_CHOICE=Gemini
LOW_RISK_TOKEN_THRESHOLD=500

# Language handling
LANGUAGE_DETECTION_ENABLED=true
# Use these exact spellings: English, Hindi, Spanish, French, Telugu, Tamil, Malayalam, Kannada.
# When true, answers are translated into TRANSLATION_TARGET_LANGUAGE.
# When false, answers follow the detected user language.
TRANSLATION_ENABLED=false
TRANSLATION_TARGET_LANGUAGE=English

# Secrets: read API keys from Secret Manager when enabled.
SECRET_MANAGER_ENABLED=false
GROQ_API_KEY_SECRET=groq-api-key
GEMINI_API_KEY_SECRET=gemini-api-key

# Security / audit
PII_REDACTION_ENABLED=true
PROMPT_VALIDATION_ENABLED=true
# Add extra forbidden-topic regexes separated with ||
FORBIDDEN_TOPIC_PATTERNS=
OUTPUT_MODERATION_ENABLED=true
# Add extra output-moderation regexes separated with ||
OUTPUT_MODERATION_PATTERNS=
REFERENCE_CHECKING_ENABLED=true
AUDIT_PROMPT_PREVIEW_ENABLED=false
