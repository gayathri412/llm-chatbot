[firebase]
web_api_key = "replace_with_firebase_web_api_key"
project_id = "replace_with_firebase_project_id"
storage_bucket = "replace_with_firebase_storage_bucket"

[auth]
provider = "firebase"

[oidc]
provider_name = "Azure AD or Okta"
discovery_url = "replace_with_oidc_discovery_url"
client_id = "replace_with_oidc_client_id"
client_secret = "replace_with_oidc_client_secret"
redirect_uri = "replace_with_app_redirect_uri"
scopes = "openid profile email"
allowed_domains = "example.com"
allowed_emails = "admin@example.com"
